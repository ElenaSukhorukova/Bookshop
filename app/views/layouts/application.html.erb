<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title>
      <%= content_for?(:title) ? yield(:title) : 'Bookshop' %>
    </title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application.scss.css", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- icons -->
    <script src="https://kit.fontawesome.com/779d459ff2.js" crossorigin="anonymous"></script>
  </head>

  <body>
    <main>
      <%= render 'shared/external_navbar' %>
      <%= yield %>
    </main>
  </body>
</html>
